<mvc:View
    controllerName="etiquetas.controller.View1"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns:core="sap.ui.core"
    xmlns:f="sap.f"
    xmlns:cssgrid="sap.ui.layout.cssgrid"
    xmlns="sap.m">

    <f:DynamicPage
        id="page"
        headerExpanded="true"
        toggleHeaderOnTitleClick="false">

        <f:title>
            <f:DynamicPageTitle>
                <f:heading>
                    <VBox>
                        <Title
                            text="{i18n>cockpitTitle}"
                            level="H1" />
                        <Text text="{i18n>cockpitSubtitle}" />
                    </VBox>
                </f:heading>

                <f:expandedContent>
                    <Text text="{i18n>cockpitDescription}" />
                </f:expandedContent>

                <f:snappedContent>
                    <Text text="{i18n>cockpitDescription}" />
                </f:snappedContent>
            </f:DynamicPageTitle>
        </f:title>

        <f:content>
            <VBox
                items="{
                    path: 'app>/featureGroups',
                    templateShareable: false
                }"
                class="sapUiResponsiveContentPadding">
                <items>
                    <Panel
                        headerText="{app>title}"
                        class="sapUiMediumMarginBottom">
                        <Text
                            text="{app>description}"
                            class="sapUiSmallMarginBeginEnd sapUiSmallMarginBottom" />

                        <f:GridList
                            items="{
                                path: 'app>features',
                                templateShareable: false
                            }"
                            showSeparators="None"
                            width="auto"
                            class="sapUiSmallMarginBeginEnd sapUiSmallMarginBottom">
                            <f:customLayout>
                                <cssgrid:GridBoxLayout
                                    boxesPerRowConfig="XL3 L3 M2 S1" />
                            </f:customLayout>

                            <f:GridListItem
                                type="Navigation"
                                press=".onModulePress">
                                <VBox class="sapUiSmallMargin">
                                    <HBox
                                        alignItems="Start"
                                        width="100%">
                                        <core:Icon
                                            src="{app>icon}"
                                            size="2rem"
                                            class="sapUiSmallMarginEnd sapUiTinyMarginTop" />

                                        <VBox>
                                            <layoutData>
                                                <FlexItemData
                                                    growFactor="1"
                                                    shrinkFactor="1" />
                                            </layoutData>

                                            <Title
                                                text="{app>title}"
                                                level="H4"
                                                wrapping="true" />

                                            <Text
                                                text="{app>description}"
                                                wrapping="true"
                                                class="sapUiTinyMarginTop" />
                                        </VBox>
                                    </HBox>

                                    <ObjectStatus
                                        text="{app>statusText}"
                                        state="Information"
                                        class="sapUiSmallMarginTop" />
                                </VBox>
                            </f:GridListItem>
                        </f:GridList>
                    </Panel>
                </items>
            </VBox>
        </f:content>
    </f:DynamicPage>
</mvc:View>
